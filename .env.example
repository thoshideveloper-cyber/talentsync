# Copy to .env and fill in values — never commit .env

# Database (Railway provides this automatically when you add a Postgres plugin)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/talentsync

# LLM Keys (at least one Google key required)
GOOGLE_API_KEY=
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=
GOOGLE_API_KEY_4=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Auth
SECRET_KEY=change-me-min-32-chars-random-string

# Default seed users (change before deploying)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=changeme123
HR_EMAIL=hr@yourcompany.com
HR_PASSWORD=hr123456

# CORS — add your Vercel URL here after deploy
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
